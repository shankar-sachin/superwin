// Win32 version resource so the exe reports 1.0.0.0 in its properties and the
// auto-updater can read a baseline version from the binary.
#include <winver.h>
#include "Version.h"

// Application icon: the lowest-numbered ICON resource becomes the exe's icon in
// Explorer / the taskbar. The .ico lives under assets/ at the repo root.
1 ICON "..\\assets\\SuperWin.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    SUPERWIN_VERSION_RC
 PRODUCTVERSION SUPERWIN_VERSION_RC
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"  // U.S. English, Unicode
        BEGIN
            VALUE "CompanyName",      "SuperWin"
            VALUE "FileDescription",  "SuperWin — Windows multi-tool"
            VALUE "FileVersion",      SUPERWIN_VERSION_STRING ".0"
            VALUE "InternalName",     "SuperWin"
            VALUE "OriginalFilename", "SuperWin.exe"
            VALUE "ProductName",      "SuperWin"
            VALUE "ProductVersion",   SUPERWIN_VERSION_STRING ".0"
            VALUE "LegalCopyright",   "Copyright (C) 2026"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
